<Page x:Class="prakt8.pages.redactInfo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:prakt8.pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="redactInfo">
    <StackPanel x:Name="createsp" Orientation="Vertical" Margin="15" HorizontalAlignment="Stretch" VerticalAlignment="Center">
        <Label Content="Фамилия"/>
        <TextBox Text="{Binding Surname, Mode=TwoWay}"/>
        <Label Content="Имя"/>
        <TextBox Text="{Binding Name, Mode=TwoWay}"/>
        <Label Content="Отчество"/>
        <TextBox Text="{Binding Middlename, Mode=TwoWay}"/>
        <Label Content="Дата рождения"/>
        <DatePicker Text="{Binding Bday, Mode=TwoWay}"/>
        <Label Content="Номер телефона"/>
        <TextBox Text="{Binding PhoneNumber, Mode=TwoWay}"/>

        <Button Content="Изменить" Margin="0 15 0 0" Click="Button_Click"/>
        <Button x:Name="exitBtn" Content="Назад" Margin="0 5 0 0" Click="exitBtn_Click"/>
    </StackPanel>
</Page>
