<Page x:Class="prakt8.pages.register"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:prakt8.pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="register">
    <StackPanel x:Name="regDoc" HorizontalAlignment="Center" VerticalAlignment="Center" Width="400px">
        <Label Content="Фамилия" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <TextBox x:Name="surnameTb" Text="{Binding Surname, Mode=OneWayToSource}" Width="200px"/>
        <Label Content="Имя" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <TextBox x:Name="nameTb" Text="{Binding Name, Mode=OneWayToSource}" Width="200px"/>
        <Label Content="Отчество" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <TextBox x:Name="middleTb" Text="{Binding Middlename, Mode=OneWayToSource}" Width="200px"/>
        <Label Content="Специальность" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <TextBox x:Name="specTb" Text="{Binding Spec, Mode=OneWayToSource}" Width="200px"/>
        <Label Content="Пароль" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <TextBox x:Name="passwordTb" Text="{Binding Pass, Mode=OneWayToSource}" Width="200px"/>
        <Button Content="Регистрация" HorizontalAlignment="Center" VerticalAlignment="Center" Click="Button_Click" Margin="0 20" Width="200px"/>
        <Button x:Name="backBtn" Content="Вернутся на прошлую страницу" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0 20" Width="200px" Click="backBtn_Click"/>
    </StackPanel>
</Page>
