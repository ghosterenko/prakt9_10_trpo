<Page x:Class="prakt8.pages.mainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:prakt8.pages"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="mainPage">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50px"/>
            <RowDefinition Height="50px"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40px"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="left" VerticalAlignment="Center">
            <Button x:Name="createPacientBtn" Width="150px" Height="20px" Margin="10 0 0 0" Content="Создать пациента" Click="createPacientBtn_Click"/>
            <Button x:Name="startPriemBtn" Width="150px" Height="20px" Margin="10 0 0 0" Content="Начать прием" Click="startPriemBtn_Click"/>
            <Button x:Name="redactInfoBtn" Width="150px" Height="20px" Margin="10 0 0 0" Content="Изменить информацию" Click="redactInfoBtn_Click"/>
            <Button x:Name="settingBtn" Content="Настройки" Height="20px" Margin="10 0 0 0" Width="150px" Click="settingBtn_Click"/>
        </StackPanel>
        <StackPanel x:Name="docInfo" Grid.Row="1" HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Horizontal">
            <Label Content="{Binding Surname}" FontSize="18px"/>
            <Label Content="{Binding Name}" FontSize="18px"/>
            <Label Content="{Binding Middlename}" FontSize="18px"/>
            <Label Content="{Binding Spec}" FontSize="18px"/>
        </StackPanel>

        <ListView x:Name="listpac" ItemsSource="{Binding pacients, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="2" Width="400" HorizontalAlignment="Left" VerticalAlignment="Stretch" Margin="15">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Vertical">
                        <StackPanel Orientation="Horizontal">
                            <Label Content="ФИО: "/>
                            <Label Content="{Binding Surname}"/>
                            <Label Content="{Binding Name}"/>
                            <Label Content="{Binding Middlename}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label Content="Дата рождения: "/>
                            <Label Content="{Binding Bday, StringFormat={}{0:dd.MM.yyyy}}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label Content="Номер телефона: "/>
                            <Label Content="{Binding PhoneNumber, StringFormat={}{0:}}"/>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>



        <StackPanel x:Name="blockDown" Orientation="Horizontal" Grid.Row="3" Background="AntiqueWhite">
            <Label Content="Всего в списке: " FontSize="18px"/>
            <Label Content="{Binding pacients.Count, UpdateSourceTrigger=PropertyChanged}" FontSize="18px"/>
        </StackPanel>

    </Grid>
</Page>
