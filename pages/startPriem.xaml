<Page x:Class="prakt8.pages.startPriem"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:prakt8.pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="startPriem">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <StackPanel x:Name="priemAdd" Grid.Column="0" Margin="10" VerticalAlignment="Center" HorizontalAlignment="Stretch">
            <Label Content="Диагноз"/>
            <TextBox Text="{Binding Diagnos, Mode=TwoWay}"/>
            <Label Content="Рекомендации"/>
            <TextBox Text="{Binding Recomendation, Mode=TwoWay}" Height="60px"/>

            <Button x:Name="addPriemBtn" Content="Добавить" Margin="0 10 0 0" Click="addPriemBtn_Click"/>
            <Button x:Name="exitBtn" Content="Назад" Margin="0 10 0 0" Click="exitBtn_Click"/>
        </StackPanel>

        <ListView x:Name="lvDc" ItemsSource="{Binding Priems, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" Margin="10" HorizontalAlignment="Center" VerticalAlignment="Stretch" Width="350px">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Vertical">
                        <StackPanel Orientation="Horizontal">
                            <Label Content="Последний прием"/>
                            <Label Content="{Binding LastP, StringFormat={}{0:dd.MM.yyyy}}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label Content="Последений доктор"/>
                            <Label Content="{Binding Lastdoc}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label Content="Диагноз"/>
                            <Label Content="{Binding Diagnos}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label Content="Рекомендации"/>
                            <Label Content="{Binding Recomendation}"/>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </Grid>
</Page>
