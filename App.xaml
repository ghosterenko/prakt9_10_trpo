<Application x:Class="prakt8.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:prakt8"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/theme/LightTheme.xaml"/>
                <ResourceDictionary Source="/Styles/UI/Button.xaml"/>
                <ResourceDictionary Source="/Styles/UI/Text.xaml"/>
                <ResourceDictionary Source="/Styles/UI/Page.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
